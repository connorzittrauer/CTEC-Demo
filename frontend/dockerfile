# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm install

# Copy rest of app
COPY . .

# Build the app
RUN npm run build


# Production stage
FROM node:20-alpine

WORKDIR /app

# Install a simple static server
RUN npm install -g serve

# Copy built files
COPY --from=builder /app/dist ./dist

# Expose port
EXPOSE 5173

# Run the app
CMD ["serve", "-s", "dist", "-l", "5173", "--single"]